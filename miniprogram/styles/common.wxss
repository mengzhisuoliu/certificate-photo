/**
 * 公共 UI 组件 — 设计系统 v2
 */

/* ========== 布局 ========== */
.page-wrap {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: var(--color-bg-page);
}

.page-content {
  padding: var(--spacing-page);
  box-sizing: border-box;
}

.page-content--white {
  background-color: var(--color-bg-card);
}

.page-content--bottom-safe {
  padding-bottom: 160rpx;
}

.text-center {
  text-align: center;
}

/* ========== 搜索框 ========== */
.search-bar {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 28rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-primary);
  border-radius: var(--radius-pill);
  box-sizing: border-box;
  box-shadow: var(--shadow-xs);
}

.search-bar--tap {
  color: var(--color-text-placeholder);
  font-size: var(--font-base);
}


.search-bar__input {
  flex: 1;
  height: 80rpx;
  font-size: var(--font-base);
  color: var(--color-text);
}

.search-bar__icon {
  flex-shrink: 0;
  padding: 8rpx;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  width: 100%;
  height: 88rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xs);
  overflow: hidden;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  position: relative;
  transition: color 0.2s;
}

.tab-bar__item--active {
  color: var(--color-primary);
  font-weight: 600;
  background-color: var(--color-primary-light);
}

/* ========== 列表项 ========== */
.photo-list-item {
  box-sizing: border-box;
  width: 100%;
  padding: 32rpx 100rpx 32rpx 40rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  position: relative;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-xs);
  overflow: hidden;
}

.photo-list-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  background: var(--color-primary-gradient);
  border-radius: 0 4rpx 4rpx 0;
}

.photo-list-item__title {
  font-size: var(--font-base);
  color: var(--color-text);
  font-weight: 600;
}

.photo-list-item__desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: 10rpx;
}

.photo-list-item__icon {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.7;
}

/* ========== 区块标题 ========== */
.section-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text);
  padding: var(--spacing-section) 0 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary-gradient);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title--with-icon::before {
  display: none;
}

.section-title--with-icon image {
  width: 184rpx;
  height: 50rpx;
}

/* ========== 信息卡片 ========== */
.info-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-card);
  margin-bottom: 20rpx;
  font-size: var(--font-base);
  line-height: 1.8;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.info-card__row {
  display: flex;
  padding: 8rpx 0;
}

.info-card__label {
  color: var(--color-text-secondary);
  width: 160rpx;
  flex-shrink: 0;
}

.info-card__value {
  flex: 1;
  color: var(--color-text);
}

/* ========== 免责声明卡片 ========== */
.disclaimer-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  font-size: var(--font-sm);
  line-height: 1.7;
  color: var(--color-text-secondary);
  border-left: 6rpx solid var(--color-warning);
  box-shadow: var(--shadow-xs);
}

/* ========== 功能入口 ========== */
.feature-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.feature-grid__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 96rpx;
}

.feature-grid__icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-xs);
}

.feature-grid__icon image {
  width: 52rpx;
  height: 52rpx;
}

.feature-grid__label {
  font-size: var(--font-xs);
  color: var(--color-text);
  text-align: center;
  line-height: 1.3;
}

/* ========== 轮播 ========== */
.banner-swiper {
  width: calc(100% - 64rpx);
  height: 280rpx;
  margin: 24rpx 32rpx 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

/* ========== 上传区域 ========== */
.tool-page {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  background-color: var(--color-bg-page);
  padding: 0 var(--spacing-page) 60rpx;
  box-sizing: border-box;
}

.tool-page .section-title {
  margin-top: 16rpx;
}

.tool-page__action {
  width: 100%;
  margin-top: 32rpx;
}

.tool-page__action--lg {
  margin-top: 48rpx;
}

.upload-box {
  position: relative;
  width: 100%;
  height: 640rpx;
  margin-top: 32rpx;
  border: 2rpx dashed var(--color-border-primary);
  border-radius: var(--radius-lg);
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-card);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.upload-box image {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-placeholder__icon {
  width: 160rpx;
  height: 160rpx;
}

.upload-placeholder__hint {
  margin-top: 28rpx;
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
  line-height: 1.4;
}

.upload-meta {
  width: 100%;
  margin-top: 24rpx;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.tool-form {
  width: 100%;
  margin-top: 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 8rpx 28rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

/* ========== 表单 ========== */
.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  font-size: var(--font-base);
  border-bottom: 1rpx solid var(--color-border);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row__label {
  width: 140rpx;
  color: var(--color-text);
  flex-shrink: 0;
  font-weight: 500;
}

.form-row__input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  margin-left: 16rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-base);
  text-align: right;
  color: var(--color-text);
  background: var(--color-bg-muted);
}

.form-row__input--wide {
  flex: 1;
}

.form-row__unit {
  margin-left: 8rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.form-card {
  width: calc(100% - 64rpx);
  margin: 32rpx auto 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.form-card__group {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.form-card__group:last-child {
  border-bottom: none;
}

.form-card__label {
  width: 240rpx;
  font-size: var(--font-base);
  color: var(--color-text);
  font-weight: 500;
  flex-shrink: 0;
}

.form-card__input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
  text-align: right;
}

.form-card__footer {
  padding: 32rpx 28rpx;
}

/* ========== 按钮 ========== */
.btn-primary {
  background: var(--color-primary-gradient) !important;
  color: #fff !important;
  font-weight: 500 !important;
  font-size: var(--font-base) !important;
  border-radius: var(--radius-btn) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  padding: 0 !important;
  border: none !important;
  box-shadow: 0 8rpx 24rpx rgba(62, 133, 238, 0.35);
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: var(--color-bg-card) !important;
  color: var(--color-primary) !important;
  font-weight: 500 !important;
  font-size: var(--font-base) !important;
  border-radius: var(--radius-btn) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  padding: 0 !important;
  border: 2rpx solid var(--color-primary) !important;
  box-shadow: var(--shadow-xs);
}

.btn-secondary::after {
  border: none;
}

.btn-success {
  background: linear-gradient(135deg, #4CD964 0%, #34C759 100%) !important;
  color: #fff !important;
  font-weight: 500 !important;
  border-radius: var(--radius-btn) !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  padding: 0 !important;
  border: none !important;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.35);
}

.btn-success::after {
  border: none;
}

.btn-block {
  width: 100% !important;
}

.btn-group {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-group .btn-primary,
.btn-group .btn-secondary {
  flex: 1;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 20rpx var(--spacing-page) calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-sizing: border-box;
  box-shadow: var(--shadow-bar);
  z-index: 999;
}

.bottom-bar .btn-primary,
.bottom-bar .btn-secondary {
  width: 100%;
}

/* ========== 个人中心 ========== */
.profile-header {
  background: var(--color-primary-gradient);
  padding: 48rpx var(--spacing-page) 80rpx;
  position: relative;
  overflow: hidden;
}

.profile-header__bg {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.profile-header__user {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.profile-header__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.profile-header__avatar image {
  width: 100%;
  height: 100%;
}

.profile-header__info {
  flex: 1;
  margin-left: 24rpx;
}

.profile-header__name {
  font-size: var(--font-lg);
  color: #fff;
  font-weight: 600;
}

.profile-header__action {
  margin-top: 12rpx;
}

.profile-header__action,
.profile-header__action button {
  background: rgba(255, 255, 255, 0.25) !important;
  color: #fff !important;
  font-size: var(--font-sm) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.4) !important;
  border-radius: var(--radius-pill) !important;
  padding: 0 24rpx !important;
  height: 56rpx !important;
  line-height: 56rpx !important;
  display: inline-block;
}

.profile-header__sign {
  flex-shrink: 0;
  margin-left: auto;
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  white-space: nowrap;
}

.profile-header__sign--active {
  background: rgba(255, 255, 255, 0.35);
  font-weight: 600;
}

.stats-card {
  display: flex;
  margin: -48rpx var(--spacing-page) 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  position: relative;
  z-index: 2;
  overflow: hidden;
}

.stats-card__item {
  flex: 1;
  text-align: center;
  padding: 36rpx 16rpx;
  position: relative;
}

.stats-card__item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 30%;
  height: 40%;
  width: 1rpx;
  background: var(--color-border);
}

.stats-card__value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.stats-card__value--green {
  color: var(--color-success);
}

.stats-card__unit {
  font-size: var(--font-sm);
  font-weight: 400;
}

.stats-card__label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* ========== 菜单列表 ========== */
.menu-card {
  margin: var(--spacing-section) var(--spacing-page);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item::after {
  content: '›';
  position: absolute;
  right: 28rpx;
  font-size: 36rpx;
  color: var(--color-text-placeholder);
  font-weight: 300;
}

.menu-item button {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  text-align: left;
  line-height: normal;
}

.menu-item__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-item__icon--red { background: #FFF0F0; }
.menu-item__icon--blue { background: var(--color-primary-light); }
.menu-item__icon--green { background: #F0FFF4; }
.menu-item__icon--orange { background: #FFF8F0; }

.menu-item__text {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
  font-weight: 500;
}

.menu-item__text--muted {
  color: var(--color-text-secondary);
}

/* ========== 素材选择网格 ========== */
.asset-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.asset-page .tab-bar {
  margin: 0 var(--spacing-page) 20rpx;
}

.asset-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 var(--spacing-page) 32rpx;
}

.asset-item {
  width: 48%;
  padding-bottom: 48%;
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--color-border);
}

.asset-item image {
  position: absolute;
  width: 88%;
  height: 88%;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  margin: auto;
}

.asset-item__badge {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(62, 133, 238, 0.85);
  color: #fff;
  font-size: var(--font-xs);
  text-align: center;
  line-height: 48rpx;
  height: 48rpx;
}

/* ========== 邀请列表 ========== */
.invite-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.invite-item:last-child {
  border-bottom: none;
}

.invite-item__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: var(--color-bg-muted);
  flex-shrink: 0;
  background-size: cover;
  background-position: center;
}

.invite-item__name {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
}

.invite-item__btn {
  width: 140rpx !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  font-size: var(--font-sm) !important;
  border-radius: var(--radius-pill) !important;
  padding: 0 !important;
  margin: 0 !important;
}

/* ========== 工具类 ========== */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-success { color: var(--color-success); }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }

.bg-primary {
  background: var(--color-primary-gradient);
  color: #fff;
}

.margin-section {
  margin: var(--spacing-section) 0;
}

.margin-top {
  margin-top: 24rpx;
}

.openid-card {
  margin: var(--spacing-section) var(--spacing-page);
  padding: 20rpx 24rpx;
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  text-align: center;
  word-break: break-all;
}

.footer-link {
  text-align: center;
  padding: 32rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.footer-link__action {
  color: var(--color-primary);
  font-weight: 500;
}
