.pre-edit-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-page);
  overflow: hidden;
}

.pre-edit-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.pre-edit-body {
  padding: var(--spacing-page);
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

.pre-edit-bottom.bottom-bar {
  position: relative;
  left: auto;
  bottom: auto;
  flex-shrink: 0;
  z-index: 1;
}

.pre-edit-bottom .btn-primary {
  text-align: center;
}

ad {
  margin-bottom: 24rpx;
}

.result-canvas-view {
  position: absolute;
  left: 100vw;
  top: 100vh;
}
