<view class="tool-page">
  <view class="section-title">压缩完成</view>

  <view class="upload-box">
    <image src="{{imageSrc}}" mode="aspectFit" bind:tap="preView" />
  </view>

  <view class="upload-meta">压缩后占用 {{size}} KB</view>

  <view class="tool-page__action tool-page__action--lg">
    <button bind:tap="downloadClick" class="btn-primary btn-block">保存到相册</button>
  </view>
</view>
