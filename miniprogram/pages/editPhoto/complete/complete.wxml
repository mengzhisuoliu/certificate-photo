<view class="page-wrap page-content">
  <view class="complete-hero">
    <view class="complete-hero__icon">✓</view>
    <view class="complete-hero__title">制作完成</view>
    <view class="complete-hero__msg">{{msg}}</view>
  </view>

  <view class="complete-preview">
    <image bindtap="preView" mode="aspectFit" src="{{url}}" class="complete-preview__img"></image>
  </view>

  <view class="info-card text-center">
    请在 <text class="text-danger">手机相册</text> 查看下载结果
  </view>

  <view class="action-group">
    <button class="btn-primary btn-block" open-type="share">分享给朋友</button>
    <button bindtap="contineu" class="btn-success btn-block margin-top">再来一张</button>
  </view>

  <ad unit-id="adunit-5ad655824a82ac5e" ad-type="video" ad-theme="white"></ad>
</view>
