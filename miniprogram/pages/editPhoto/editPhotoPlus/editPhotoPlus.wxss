/* 证件照编辑器 */
page {
  background: var(--color-bg-page);
}

.container {
  width: 100%;
  overflow: hidden;
  padding-bottom: 32rpx;
}

/* 画布区域 */
.pthto-edit-content {
  padding: 24rpx var(--spacing-page);
  width: 100%;
  box-sizing: border-box;
}

.pthto-edit-content .canvas-view {
  position: relative;
  margin: 0 auto;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 4rpx solid var(--color-bg-card);
}

.pthto-edit-content .canvas-view .people-photo {
  position: absolute;
  transform-origin: center center;
}

/* 新手引导 */
.pthto-edit-content .canvas-view .guide {
  position: absolute;
  z-index: 9;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 26, 46, 0.6);
  backdrop-filter: blur(4px);
}

.pthto-edit-content .canvas-view .guide .guide-know {
  position: absolute;
  width: 200rpx;
  line-height: 72rpx;
  height: 72rpx;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  margin: auto;
  border-radius: var(--radius-pill);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  text-align: center;
  font-size: var(--font-base);
  font-weight: 500;
}

.pthto-edit-content .canvas-view .guide text {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  margin: auto;
  color: #fff;
  text-align: center;
  font-size: var(--font-md);
  font-weight: 500;
  line-height: 1.6;
  padding: 0 32rpx;
}

.pthto-edit-content .canvas-view .guide image {
  position: absolute;
  width: 180rpx;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  margin: auto;
}

/* 侧边浮动按钮 */
.gesture {
  width: 100%;
  position: relative;
  overflow: visible;
  z-index: 2;
}

.gesture .fab-btn {
  position: absolute;
  width: 104rpx;
  height: 104rpx;
  text-align: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-fab);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-border);
}

.gesture .right {
  right: 16rpx;
}

.gesture .left {
  left: 16rpx;
}

.gesture .change-clothes {
  bottom: 24rpx;
}

.gesture .change-hair {
  bottom: 260rpx;
}

.gesture .look-videw {
  top: -250rpx;
}

.gesture image {
  width: 56rpx;
  height: 56rpx;
}

.style-text {
  color: var(--color-text);
  font-size: var(--font-xs) !important;
  margin-top: 4rpx;
  font-weight: 500;
}

/* 背景色选择 */
.colors {
  width: calc(100% - 64rpx);
  margin: 28rpx auto 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  background: var(--color-bg-card);
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.colors .color {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx solid var(--color-border);
  border-radius: 50%;
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.colors .color.active {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx var(--color-primary-light);
}

.blue { background-color: #438EDB; }
.blue2 { background-color: #00BFF3; }
.red { background-color: #E74C3C; }
.white { background-color: #FFFFFF; }

.colors .color.custom {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted);
}

.colors .color.custom .text {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.2;
}

.colors .color.custom .custom-bg {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

/* 颜色选择器弹层 */
.color-picker-view {
  position: relative;
  width: 100%;
  height: 0;
  overflow: visible;
  z-index: 99;
}

.color-picker-view .color-picker-content {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  background-color: var(--color-bg-card);
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  box-shadow: var(--shadow-card);
  padding-bottom: 24rpx;
}

.color-picker-view .color-picker-content .tips {
  position: absolute;
  width: 4em;
  right: 16rpx;
  top: 60rpx;
  font-size: var(--font-sm);
}

.color-picker-view .color-picker-content .current-color {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  right: 16rpx;
  bottom: 160rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border);
}

.picker-confirm-btn {
  position: absolute !important;
  right: 16rpx !important;
  bottom: 60rpx !important;
  background: var(--color-primary-gradient) !important;
  color: #fff !important;
  border-radius: var(--radius-pill) !important;
  font-size: var(--font-sm) !important;
  padding: 0 32rpx !important;
  border: none !important;
}

/* 下载区域 */
.count-tip {
  text-align: center;
  padding: 16rpx var(--spacing-page);
  font-size: var(--font-sm);
  color: var(--color-warning);
}

.count-tip__sub {
  display: block;
  margin-top: 4rpx;
  color: var(--color-text-secondary);
}

.download-view {
  width: 100%;
  box-sizing: border-box;
  padding: 0 var(--spacing-page);
  margin-top: 16rpx;
}

.download-view .btn-group {
  margin-bottom: 16rpx;
}

.download-view navigator {
  flex: 1;
}

.download-view navigator button {
  width: 100%;
}

.result-canvas-view {
  max-height: 1px;
  overflow: hidden;
}
