/* 首页专属样式 */
.collect-tip {
  height: 64rpx;
  line-height: 64rpx;
  color: #fff;
  font-size: var(--font-xs);
  padding: 0 28rpx;
  background: rgba(26, 26, 46, 0.75);
  position: fixed;
  top: 24rpx;
  right: 32rpx;
  z-index: 999;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  backdrop-filter: blur(8px);
}

.collect-tip.active {
  display: none;
}

.collect-tip__dot {
  border-radius: 50%;
  background: #fff;
  display: inline-block;
}

.collect-tip__dot--sm {
  width: 10rpx;
  height: 10rpx;
}

.collect-tip__dot--lg {
  width: 16rpx;
  height: 16rpx;
  margin: 0 4rpx;
}

.collect-tip__arrow {
  position: absolute;
  top: -32rpx;
  right: 100rpx;
  width: 0;
  height: 0;
  border: 16rpx solid transparent;
  border-bottom-color: rgba(26, 26, 46, 0.65);
}

.collect-tip__ok {
  margin-left: 24rpx;
  color: var(--color-danger);
  font-weight: 500;
}

.banner-item {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-item__img {
  width: 100%;
  height: 100%;
}

.banner-item__overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 28rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.banner-item__tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-sm);
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-item__tag--orange {
  background: var(--color-accent);
}

.banner-item__tag--green {
  background: var(--color-success);
}

.banner-item__desc {
  display: block;
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.95);
}

ad {
  margin-bottom: 20rpx;
}
