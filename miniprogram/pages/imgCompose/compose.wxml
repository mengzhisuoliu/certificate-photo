<view class="tool-page">
  <view class="section-title">打印排版</view>

  <view class="upload-box" bindtap="choosePic">
    <image wx:if="{{imageSrc}}" src="{{imageSrc}}" mode="aspectFit" />
    <view wx:else class="upload-placeholder">
      <image class="upload-placeholder__icon" src="../imgZip/image/choosePic.png" mode="aspectFit" />
      <text class="upload-placeholder__hint">点击上传照片</text>
    </view>
  </view>

  <view class="upload-meta">
    排版尺寸为常用 6 寸，建议原图为一寸/二寸照片
  </view>

  <view class="tool-page__action tool-page__action--lg">
    <button bind:tap="downloadClick" class="btn-primary btn-block">生成并下载</button>
  </view>
</view>
